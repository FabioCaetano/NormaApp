# Backend Norma Brasil

## Variáveis de Ambiente
PORT=3333
NODE_ENV=production
JWT_SECRET=<change-to-a-strong-random-secret>
JWT_EXPIRES_IN=24h

## Database - Development (SQLite)
# DATABASE_URL="file:./dev.db"

## Database - Production (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/normaapp?schema=public

## WhatsApp (Baileys)
WHATSAPP_ENABLED=false
BARBER_PHONE=<your-number-with-country-code>
# WHATSAPP_LOG_LEVEL=silent | debug | info | warn | error

## CORS - set to your deployed frontend URL
FRONTEND_URL=https://your-app.vercel.app
